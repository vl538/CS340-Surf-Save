<div class="header">
    <h2>Order Items</h2>
</div>

<div class="section">
    <h3>Add New Order Item</h3>
    <form action="/add-orderitem" method="POST" class="form">
        <div class="form-group">
            <select name="orderID" required>
                <option value="">Select Order</option>
                {{#each orders}}
                <option value="{{orderID}}">Order #{{orderID}} - ${{totalCost}} ({{orderDate}})</option>
                {{/each}}
            </select>
            <select name="productID" required>
                <option value="">Select Product</option>
                {{#each products}}
                <option value="{{productID}}">{{productName}} (${{price}})</option>
                {{/each}}
            </select>
        </div>
        <div class="form-group">
            <input type="number" name="quantity" placeholder="Quantity" required min="1">
        </div>
        <button type="submit" class="btn">Add Item to Order</button>
    </form>
</div>

<div class="section">
    <h3>Existing Order Items</h3>
    <table class="data-table">
        <thead>
            <tr>
                <th>Item ID</th>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Product</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th>Line Total</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {{#each orderItems}}
            <tr>
                <td>{{orderItemID}}</td>
                <td>Order #{{orderID}}</td>
                <td>{{customerName}}</td>
                <td>{{productName}}</td>
                <td>{{quantity}}</td>
                <td>${{productPrice}}</td>
                <td>${{multiply productPrice quantity}}</td>
                <td class="actions">
                    <form action="/edit-orderitem" method="GET">
                        <input type="hidden" name="orderItemID" value="{{orderItemID}}">
                        <button type="submit" class="btn-sm">Edit</button>
                    </form>
                    <form action="/delete-orderitem" method="POST">
                        <input type="hidden" name="orderItemID" value="{{orderItemID}}">
                        <button type="submit" class="btn-sm btn-danger" onclick="return confirm
                            ('Are you sure you want to delete this record?')">
                                Delete
                        </button>
                    </form>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>